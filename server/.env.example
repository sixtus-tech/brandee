# --- Anthropic (required) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Which Claude model to use. Sonnet for nuance, Haiku for speed/cost.
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- ElevenLabs (optional — voice features) ---
# Sign up at https://elevenlabs.io to get a key (free tier covers ~10k characters/month).
# If unset, voice is gracefully disabled — chat still works fine.
ELEVENLABS_API_KEY=

# Default voice is Charlotte (XB0fDUnXU5powFXDhCwa) — warm + slightly mischievous.
# Browse voices at https://elevenlabs.io/app/voice-library and paste any voice ID here.
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa

# Flash for low-latency conversational TTS. Use eleven_multilingual_v2 for higher quality.
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# --- Server config ---
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
